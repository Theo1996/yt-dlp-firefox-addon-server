{
  "manifest_version": 2,
  "name": "YT Downloader",
  "version": "1.0",
  "permissions": ["tabs", "activeTab", "http://localhost/*", "http://127.0.0.1/*"],
  "browser_specific_settings": {
    "gecko": {
      "id": "theonipponotaku@hotmail.com",
      "strict_min_version": "92.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_icon": "icon.png",
    "default_title": "Download with yt-dlp"
  }
}